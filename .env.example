# AI_AGENT_PROFILE selects which profile overlay to load: "subscription" | "apikey".
# subscription = personal profile (this repo, profiles/subscription/).
# apikey = company profile (profiles/apikey/, never committed to this repo).
AI_AGENT_PROFILE=subscription

# Only used by the apikey profile (litellm direct-api adapter). Not needed
# for subscription (subscription uses cli-bridge adapters: claude-cli / codex-cli).
LITELLM_BASE_URL=
LITELLM_TOKEN=
