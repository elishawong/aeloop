# AI_AGENT_PROFILE selects which profile overlay to load: "helix" | "verity".
# helix = personal profile (this repo, profiles/helix/).
# verity = company profile (profiles/verity/, never committed to this repo).
AI_AGENT_PROFILE=helix

# Only used by the verity profile (litellm direct-api adapter). Not needed
# for helix (helix uses cli-bridge adapters: claude-cli / codex-cli).
LITELLM_BASE_URL=
LITELLM_TOKEN=
