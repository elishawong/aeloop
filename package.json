{
  "name": "aeloop",
  "version": "0.0.1",
  "description": "Model-agnostic, governance-first coder/tester engine (Prompt ⊂ Context ⊂ Harness ⊂ Loop + profile overlay).",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "aeloop": "dist/cli/bin.js"
  },
  "files": [
    "dist/**/*",
    "profiles/*/personas/**/*.md",
    "profiles/*/config.yaml"
  ],
  "scripts": {
    "build": "node scripts/generate-version.mjs && tsc -p tsconfig.build.json",
    "test": "node scripts/generate-version.mjs && vitest run",
    "test:watch": "node scripts/generate-version.mjs && vitest",
    "lint": "node scripts/generate-version.mjs && tsc --noEmit",
    "demo:company": "pnpm run build && node scripts/demo-company.mjs",
    "conductor-work": "pnpm run build && node scripts/conductor-work.mjs"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@langchain/langgraph": "1.4.8",
    "@langchain/langgraph-checkpoint-sqlite": "1.0.3",
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.6.2",
    "js-yaml": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
