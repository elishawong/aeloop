{
  "name": "aeloop",
  "version": "0.0.1",
  "description": "Model-agnostic, governance-first coder/tester engine (Prompt ⊂ Context ⊂ Harness ⊂ Loop + profile overlay).",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist/**/*",
    "profiles/*/personas/**/*.md",
    "profiles/*/config.yaml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "js-yaml": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
