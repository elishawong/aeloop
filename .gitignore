# deps / build
node_modules/
dist/
*.tsbuildinfo

# Runtime state (per-profile memory store, not tracked in git)
*.db
*.db-journal
*.db-wal
memory.db
run-origins.json

# Run artifacts (conductor-work run outputs: events jsonl + result json, accumulate per run)
# 保留 out/ 文件夹本身(.gitkeep),但忽略里面所有 run 产物(含 dated 子文件夹)
out/*
!out/.gitkeep

# Pipeline runtime state (advance CLI single-build working state, kept local per checkout, not tracked in git)
.helix/

# Company overlay never enters this repo (lives in an internal git only)
profiles/apikey/

# Environment
.env
.env.local

# conductor-brain turnkey (issue #88): per-operator local config + one-time authorization locks,
# neither should ever be committed (brain.local.json.example is the tracked template to copy from)
.claude/brain.local.json
.claude/brain-locks/

# Misc
.DS_Store
*.log
